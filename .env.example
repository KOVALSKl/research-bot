# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=research_chunks
QDRANT_RECREATE_ON_SCHEMA_MISMATCH=true

# Dense embeddings (Ollama — default)
DENSE_EMBEDDING_PROVIDER=ollama
DENSE_VECTOR_SIZE=1024
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b
OLLAMA_TIMEOUT_SECONDS=120

# Sparse embeddings (fastembed, local)
SPARSE_EMBEDDING_MODEL=Qdrant/bm25

# Fallback dense via fastembed (when DENSE_EMBEDDING_PROVIDER=fastembed)
DENSE_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Core API
CORE_API_HOST=0.0.0.0
CORE_API_PORT=8000
