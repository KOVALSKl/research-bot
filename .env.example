# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=research_chunks
# After changing embedding models, use a new collection name or delete the old one in Qdrant.
# QDRANT_COLLECTION_NAME=research_chunks_ru
QDRANT_RECREATE_ON_SCHEMA_MISMATCH=true

# Dense embeddings — fastembed (recommended for Russian/multilingual corpora)
DENSE_EMBEDDING_PROVIDER=fastembed
DENSE_VECTOR_SIZE=1024
# Multilingual dense model (1024-dim). Do not use English-only models like bge-small-en.
DENSE_EMBEDDING_MODEL=intfloat/multilingual-e5-large

# Optional: dense via Ollama instead of fastembed
# DENSE_EMBEDDING_PROVIDER=ollama
# OLLAMA_HOST=localhost
# OLLAMA_PORT=11434
# OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b
# Для больших моделей (qwen3.6 и т.п.) увеличьте до 600+
# OLLAMA_TIMEOUT_SECONDS=600

# Sparse embeddings (fastembed, local). BM25 is language-agnostic and works for Russian.
SPARSE_EMBEDDING_MODEL=Qdrant/bm25

# Core API
CORE_API_HOST=0.0.0.0
CORE_API_PORT=8000

# Redis / Celery (background ingestion). Broker/backend default to REDIS_URL.
REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Ingestion
RESEARCHES_DIR=researches
# Document storage (v10): local filesystem or Yandex Disk
STORAGE_BACKEND=local
# STORAGE_BACKEND=yandex
# YANDEX_DISK_API_TOKEN=
# YANDEX_DISK_BASE_PATH=disk:/research-docs
# INGEST_SYNC=true processes uploads inline (no worker needed); dev/local only.
# Production must use INGEST_SYNC=false (default): fast staging write + async worker ingest.
INGEST_SYNC=false
# Transient staging directory shared by core_api and worker (Docker volume in compose).
INGEST_STAGING_DIR=researches/.staging
# Orphan staging files older than this TTL are removed by worker beat cleanup.
INGEST_STAGING_TTL_HOURS=24
INGEST_STATE_COLLECTION=ingestion_state
CHUNK_SIZE=900
CHUNK_OVERLAP=180
CHUNK_MIN_CHARS=80

# Background scanner (Celery beat) — OFF by default.
# When enabled, periodically scans researches/ and indexes new/changed PDFs.
RESEARCHES_SCAN_ENABLED=false
RESEARCHES_SCAN_INTERVAL_SECONDS=300

# LLM answer generation (/ask) — OFF by default. When false, /ask returns
# context + citations with answer=null. When enabled, default provider is Hugging Face.
LLM_ENABLED=false
LLM_PROVIDER=huggingface
# LLM_PROVIDER_MODULE=my_app.llm.CustomLLM  # required only when LLM_PROVIDER=custom

# Hugging Face Inference API (default LLM provider when LLM_ENABLED=true)
HF_API_TOKEN=
HF_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
HF_TIMEOUT_SECONDS=120

# Ollama LLM (alternative when LLM_PROVIDER=ollama)
OLLAMA_CHAT_MODEL=qwen3:0.6b

# Yandex AI Studio (openai SDK + Responses API, recommended for production)
# Supports large models like qwen3-235b without local GPU.
# LLM_PROVIDER=yandex_ai_studio
# YANDEX_AI_STUDIO_API_KEY=
# YANDEX_AI_STUDIO_FOLDER_ID=          # Yandex Cloud folder ID (обязательно)
# YANDEX_AI_STUDIO_MODEL=qwen3-235b-a22b-fp8/latest
# YANDEX_AI_STUDIO_BASE_URL=https://ai.api.cloud.yandex.net/v1
# YANDEX_AI_STUDIO_TEMPERATURE=0.3
# YANDEX_AI_STUDIO_MAX_OUTPUT_TOKENS=2000
# YANDEX_AI_STUDIO_TIMEOUT_SECONDS=120

# RAG (/ask): default chunk count and optional system prompt override
ASK_DEFAULT_LIMIT=10
# RAG_SYSTEM_PROMPT=          # empty = built-in structured prompt (see llm/prompts.py)

# Research Agent (POST /agent/ask): local context thresholds and optional LLM classifier
MIN_LOCAL_RESULTS=2
MIN_LOCAL_SCORE=0.40
# AGENT_USE_LLM_CONTEXT_CHECK=false   # false = rule-based sufficiency (default); true = LLM yes/no
# AGENT_QUESTION_PROMPT=              # empty = built-in agent prompt (see llm/prompts.py)

# Research Agent v14: relevance filter, query reformulation, streaming progress
AGENT_RELEVANCE_FILTER_ENABLED=true
AGENT_MIN_CHUNK_SCORE=0.35          # L1 score threshold for chunk relevance
AGENT_USE_LLM_RELEVANCE_FILTER=true # L2 LLM batch filter; defaults follow LLM_ENABLED
# AGENT_RELEVANCE_PROMPT=             # empty = built-in relevance prompt
AGENT_QUERY_REFORMULATION_ENABLED=true  # generates RU + EN search variants for OpenAlex/arXiv (requires LLM); fallback to original query when LLM disabled
AGENT_IDEA_QUERY_REFORMULATION_ENABLED=true
# AGENT_QUERY_REFORMULATION_PROMPT=   # empty = built-in reformulation prompt (v15: RU+EN queries)

# Research Agent v15: multilingual retrieval and evidence synthesis
AGENT_SEARCH_QUERIES_MAX=3
AGENT_SUPPLEMENT_EXTERNAL=false     # search external DB even when local context is sufficient
AGENT_SYNTHESIS_RETRY_ON_SHALLOW=true
# AGENT_MIN_CITATIONS_PER_SECTION=1

# Research Agent v6: ReAct loop
AGENT_MAX_ITERATIONS=4
# AGENT_REACT_SYSTEM_PROMPT=           # empty = built-in ReAct system prompt

# External literature search (OpenAlex, arXiv, Semantic Scholar)
LITERATURE_CACHE_TTL_SECONDS=3600
LITERATURE_CACHE_EMPTY_TTL_SECONDS=10
LITERATURE_DEFAULT_LIMIT=10
LITERATURE_IDEA_MODE_LIMIT=15
# SEMANTIC_SCHOLAR_API_KEY=   # optional; without key Semantic Scholar provider is skipped

# VK Bot (services/vk_bot)
VK_BOT_TOKEN=
VK_GROUP_ID=
VK_API_VERSION=5.199
# long_polling (dev) | callback (prod with public HTTPS URL)
VK_TRANSPORT=long_polling

# Callback API (when VK_TRANSPORT=callback)
VK_CALLBACK_SECRET=
VK_CALLBACK_CONFIRMATION=
VK_CALLBACK_HOST=0.0.0.0
VK_CALLBACK_PORT=8081
VK_CALLBACK_PATH=/vk/callback

# Core API URL for vk_bot (default matches local core_api)
CORE_API_BASE_URL=http://localhost:8000

# Redis for user upload queue and rate limiting (defaults to REDIS_URL)
# VK_BOT_REDIS_URL=redis://localhost:6379/0
VK_BOT_REDIS_KEY_PREFIX=vk_bot:

# Rate limiting: redis (prod) | memory (local dev without Redis)
VK_RATE_LIMIT_BACKEND=redis
VK_RATE_LIMIT_MAX_MESSAGES=5
VK_RATE_LIMIT_WINDOW_SECONDS=60
VK_DEBOUNCE_SECONDS=2

# Question validation
VK_MIN_QUESTION_LENGTH=12
VK_MAX_QUESTION_LENGTH=2000
VK_ASK_DEFAULT_LIMIT=10

# Per-user document batch queue
VK_USER_BATCH_TTL_SECONDS=86400
VK_BATCH_POLL_INTERVAL_SECONDS=15

# HTTP timeouts
VK_CORE_API_TIMEOUT_SECONDS=30
VK_ASK_TIMEOUT_SECONDS=660   # read timeout для /agent/ask/stream; держите > OLLAMA_TIMEOUT_SECONDS
# Startup probe before VK long polling (v11)
VK_CORE_API_STARTUP_WAIT_SECONDS=120
VK_CORE_API_STARTUP_POLL_INTERVAL_SECONDS=2
# Transient connection retry for vk_bot -> core_api (v11)
# Either naming scheme works (arch canonical names listed first)
VK_CORE_API_RETRY_MAX_ATTEMPTS=3
VK_CORE_API_RETRY_BASE_DELAY_SECONDS=1.0
# Legacy aliases (still supported)
# VK_CORE_API_RETRY_MAX=3
# VK_CORE_API_RETRY_BACKOFF_SECONDS=1.0
VK_ATTACHMENT_MAX_BYTES=52428800

# Command-first UX (v4): RAG only on explicit commands
# Comma-separated lists (JSON array also supported, e.g. ["/list","/research"])
VK_ASK_COMMAND_PREFIXES=/ask,/вопрос,?,вопрос:
VK_GREETING_KEYWORDS=привет,старт,/start,начать,hello,hi

# v5: message dedup and VK attachment enrichment
VK_MESSAGE_DEDUP_TTL_SECONDS=86400
VK_MESSAGE_ENRICH_ENABLED=true
VK_DOCS_RESOLVE_URL=true

# v6: structured logging and PDF attachment limits
VK_MAX_PDF_ATTACHMENTS=3
LOG_LEVEL=INFO
LOG_FORMAT=text

# v8: upload naming wizard and document list
VK_NAMING_SESSION_TTL_SECONDS=3600
VK_NAMING_TEMP_DIR=/tmp/vk_bot_uploads
# Comma-separated list (JSON array also supported)
VK_LIST_COMMAND_PREFIXES=/list,/исследования,/research
VK_ASK_MAX_ATTACHMENTS=1
VK_ASK_ATTACH_ENABLED=true
VK_ASK_ATTACH_MAX_BYTES=20971520
VK_HTTP_MAX_REDIRECTS=10

# Conversation history: per-user Q/A turns stored in Redis (TTL-based)
VK_CONVERSATION_HISTORY_ENABLED=true
VK_CONVERSATION_HISTORY_MAX_TURNS=5
VK_CONVERSATION_HISTORY_TTL_SECONDS=3600

# v9: external PDF cache and delivery
EXTERNAL_PDF_FETCH_ENABLED=true
EXTERNAL_PDF_CACHE_DIR=external_pdfs
EXTERNAL_PDF_MAX_BYTES=52428800
EXTERNAL_PDF_FETCH_TIMEOUT_SECONDS=60
EXTERNAL_PDF_MAX_REDIRECTS=10
